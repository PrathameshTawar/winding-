{
  "name": "@akhrot/cursor-reader",
  "version": "1.0.0",
  "description": "MCP module for tracking and reading Cursor workspace",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "node -e \"fs.rmSync('dist', {recursive:true, force:true})\" && tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "serve": "node dist/server.js",
    "test": "jest",
    "lint": "eslint src/**/*.ts"
  },
  "bin": {
    "cursor-reader-mcp": "dist/server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chokidar": "^3.5.3",
    "glob": "^10.3.0",
    "minimatch": "^9.0.3",
    "simple-git": "^3.20.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "eslint": "^8.50.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "mcp",
    "cursor",
    "workspace",
    "reader",
    "git",
    "file-watcher"
  ],
  "author": "",
  "license": "MIT"
}
